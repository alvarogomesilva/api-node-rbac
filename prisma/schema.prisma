generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id       String @id @default(uuid()) @db.Uuid
  name     String
  email    String @unique
  password String
  roleId String @db.Uuid @map("role_id")

  role Role   @relation(fields: [roleId], references: [id])

  @@map("accounts")
}

model Role {
  id       String    @id @default(uuid()) @db.Uuid
  name     String
  accounts Account[]

  @@map("roles")
}

model Permissions {
  id String @id @default(uuid()) @db.Uuid
  name String
  code String @unique

  @@map("permissions")
}
